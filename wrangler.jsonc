{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "melaninfitmen-site",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  }
}
